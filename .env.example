# ---- App ----
APP_NAME="ScamShield AI"
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=true
API_V1_PREFIX=/api/v1

# ---- Security (CHANGE IN PRODUCTION) ----
SECRET_KEY=replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# ---- Database ----
POSTGRES_USER=scamshield
POSTGRES_PASSWORD=scamshield
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=scamshield
# DATABASE_URL=postgresql+psycopg://scamshield:scamshield@db:5432/scamshield
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- CORS ----
BACKEND_CORS_ORIGINS=*

# ---- ML / Detectors ----
ENABLE_HEAVY_MODELS=false
NLP_MODEL_NAME=distilbert-base-uncased
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
OCR_ENGINE=easyocr

# ---- LLM ----
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001
# LLM_API_KEY=sk-ant-...

# ---- Observability ----
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
METRICS_ENABLED=true
# SENTRY_DSN=
