# ScamShield AI — Frontend env

# Base URL of the FastAPI backend (used by next.config rewrites to proxy /api/v1/*)
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Set to "1" to call the real /api/v1/detect/text endpoint instead of curated
# demo verdicts. Leave unset for instant, no-backend demo mode.
NEXT_PUBLIC_LIVE_API=0
